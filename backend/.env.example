# AlignOps Backend — Environment Variables
# Copy this file to .env and fill in your values

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/alignops?schema=public"

# JWT Secrets (generate with: openssl rand -hex 64)
JWT_SECRET="change_this_to_a_very_long_random_string_at_least_64_chars_long_for_security"
JWT_REFRESH_SECRET="change_this_to_another_very_long_random_string_different_from_above"

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# CORS — set to your frontend URL
CORS_ORIGIN=http://localhost:3000

# Tokens
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
